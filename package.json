{
  "name": "wnba-bet-predictor-2026",
  "version": "1.6.0",
  "description": "2026 WNBA Bet Predictor — decision-driven betting intelligence platform",
  "main": "server/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "electron:dev": "electron desktop/main.js",
    "build:server": "esbuild server/index.js --bundle --platform=node --target=node18 --outfile=dist-server/server.bundle.js",
    "electron:build": "npm run build:server && electron-builder && node scripts/copy-launchers.js",
    "electron:build:win": "npm run build:server && electron-builder --win && node scripts/copy-launchers.js",
    "electron:build:zip": "npm run build:server && electron-builder --win zip && node scripts/copy-launchers.js",
    "electron:launchers": "node scripts/copy-launchers.js",
    "postinstall": "node scripts/install-electron-binary.js",
    "electron:icons": "node scripts/generate-app-icons.js",
    "build:vercel": "npx vercel build",
    "deploy": "npx vercel deploy --prebuilt",
    "test": "node scripts/test-engine.js",
    "build:exe": "node scripts/build-exe.js",
    "make:exe": "node scripts/build-exe.js",
    "build:share": "node scripts/prepare-share.js",
    "test:engine": "node scripts/test-engine.js",
    "test:api": "node scripts/test-api.js",
    "smoke:electron": "node scripts/smoke-electron-build.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-log": "^5.4.4",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "pkg": "^5.8.1"
  },
  "build": {
    "appId": "com.meepmap.wnba-bet-predictor",
    "productName": "MeepMap",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "desktop/**/*",
      "!desktop/test-require.js",
      "app.js",
      "index.html",
      "js/**/*",
      "styles.css",
      "data/**/*",
      "assets/**/*",
      "dist-server/server.bundle.js"
    ],
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "extraFiles": [
      {
        "from": "launch",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  },
  "pkg": {
    "scripts": [
      "server/**/*.js"
    ],
    "assets": [
      "index.html",
      "app.js",
      "styles.css",
      "js/**/*",
      "data/**/*",
      "assets/**/*",
      "server/**/*",
      "SHARE.txt"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}
